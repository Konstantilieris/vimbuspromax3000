{
  "name": "@vimbuspromax3000/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./repositories": "./src/repositories/index.ts",
    "./testing": "./src/testing.ts"
  },
  "scripts": {
    "db:generate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prisma.ps1 generate",
    "db:migrate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prisma.ps1 migrate dev",
    "db:migrate:init": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prisma.ps1 migrate dev --name init"
  },
  "dependencies": {
    "@libsql/client": "0.17.3",
    "@prisma/adapter-libsql": "7.8.0",
    "@prisma/client": "7.8.0",
    "@vimbuspromax3000/shared": "workspace:*",
    "@vimbuspromax3000/verification": "workspace:*"
  }
}
